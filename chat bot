    <script>
        let resumeData = null;

        // Auto-load JSON on page load
        window.onload = async function() {
            try {
                const response = await fetch('resume_data.json');
                if (!response.ok) {
                    throw new Error('Failed to load resume data');
                }
                
                const data = await response.json();
                resumeData = data;
                
                // Filter successful resumes
                const successfulResumes = data.resumes.filter(r => r.status === 'success');
                
                // Update stats
                document.getElementById('totalCandidates').textContent = successfulResumes.length;
                
                const avgExp = successfulResumes.reduce((sum, r) => 
                    sum + (r.work_experience?.total_years || 0), 0) / successfulResumes.length;
                document.getElementById('avgExperience').textContent = avgExp.toFixed(1) + ' yrs';
                
                document.getElementById('statusIndicator').className = 'status-indicator connected';
                document.getElementById('statusText').textContent = 'Ready';
                
                // Enable chat input
                document.getElementById('userInput').disabled = false;
                document.getElementById('sendBtn').disabled = false;
                document.getElementById('quickQuestions').style.display = 'flex';
                
                // Update candidate list
                updateCandidateList(successfulResumes);
                
                // Add success message
                addBotMessage(`✅ Loaded ${successfulResumes.length} candidates successfully! You can now ask me questions.`);
                
            } catch (error) {
                document.getElementById('statusIndicator').className = 'status-indicator disconnected';
                document.getElementById('statusText').textContent = 'Error';
                addBotMessage(`❌ Error loading resume data: ${error.message}`);
            }
        };

        // Update candidate list in sidebar
        function updateCandidateList(candidates) {
            const list = document.getElementById('candidateList');
            list.innerHTML = '';
            
            candidates.slice(0, 10).forEach(candidate => {
                const card = document.createElement('div');
                card.className = 'candidate-card';
                card.innerHTML = `
                    <div class="candidate-name">${candidate.name}</div>
                    <div class="candidate-info">
                        💼 ${candidate.work_experience?.total_years || 0} years
                    </div>
                `;
                card.onclick = () => askQuestion(`Tell me about ${candidate.name}`);
                list.appendChild(card);
            });
        }

        // Apply quick filter
        function applyFilter(filter) {
            if (!resumeData) return;
            
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            let question = '';
            switch(filter) {
                case 'all':
                    question = 'Show me all candidates with their experience and skills';
                    break;
                case 'exp>5':
                    question = 'Find candidates with more than 5 years experience';
                    break;
                case 'exp<3':
                    question = 'Find candidates with less than 3 years experience';
                    break;
                case 'bachelor':
                    question = "Show candidates with Bachelor's degree";
                    break;
                case 'master':
                    question = "Show candidates with Master's degree";
                    break;
            }
            
            askQuestion(question);
        }

        // Send message
        async function sendMessage() {
            const input = document.getElementById('userInput');
            const message = input.value.trim();
            
            if (!message || !resumeData) return;
            
            input.value = '';
            addUserMessage(message);
            await getBotResponse(message);
        }

        // Ask predefined question
        function askQuestion(question) {
            document.getElementById('userInput').value = question;
            sendMessage();
        }

        // Add user message to chat
        function addUserMessage(text) {
            const messagesContainer = document.getElementById('chatMessages');
            const typingIndicator = document.getElementById('typingIndicator');
            
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message user';
            messageDiv.innerHTML = `<div class="message-content">${text}</div>`;
            
            // Insert before typing indicator
            messagesContainer.insertBefore(messageDiv, typingIndicator);
            
            // Scroll to bottom
            setTimeout(() => {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 100);
        }

        // Add bot message to chat
        function addBotMessage(text) {
            const messagesContainer = document.getElementById('chatMessages');
            const typingIndicator = document.getElementById('typingIndicator');
            
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message bot';
            messageDiv.innerHTML = `<div class="message-content">${text}</div>`;
            
            // Insert before typing indicator
            messagesContainer.insertBefore(messageDiv, typingIndicator);
            
            // Scroll to bottom
            setTimeout(() => {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 100);
        }

        // Get bot response using Ollama
        async function getBotResponse(userQuestion) {
            const typingIndicator = document.getElementById('typingIndicator');
            typingIndicator.classList.add('active');
            
            try {
                // Build context from resume data
                const successfulResumes = resumeData.resumes.filter(r => r.status === 'success');
                const context = buildContext(successfulResumes);
                
                // Create prompt
                
                const prompt = `You are a helpful recruitment assistant. Answer questions about candidates based on the resume database.

RESUME DATABASE:
${context}

USER QUESTION: ${userQuestion}

INSTRUCTIONS:
1. Answer based ONLY on the resume data provided above
2. When mentioning candidates, format as: **Name** (Experience: X years)
3. Be specific - mention experience years, qualifications, key skills
4. If multiple candidates match, list them with bullet points
5. If no candidates match, say so clearly
6. Keep answers concise and well-formatted
7. Use emojis to make responses engaging (💼 for experience, 🎓 for education, 🛠️ for skills)

Answer:`;

                // Call Ollama API
                const response = await fetch('http://127.0.0.1:11434/api/generate', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        model: 'llama3.2:1b',
                        prompt: prompt,
                        stream: false,
                        options: {
                            temperature: 0.7,
                            top_p: 0.9
                        }
                    })
                });

                if (!response.ok) {
                    throw new Error(`Ollama API error: ${response.statusText}`);
                }

                const data = await response.json();
                const answer = data.response.trim();
                
                typingIndicator.classList.remove('active');
                addBotMessage(answer);
                
            } catch (error) {
                typingIndicator.classList.remove('active');
                addBotMessage(`❌ Error: ${error.message}<br><br>⚠️ Please make sure Ollama is running:<br><code>ollama serve</code><br><code>ollama pull llama3.2:1b</code>`);
            }
        }

        // Build context from resume data
        function buildContext(resumes) {
            let context = '';
            
            resumes.forEach((resume, idx) => {
                const workExp = resume.work_experience || {};
                const quals = resume.qualifications || {};
                const highestQual = quals.highest_qualification || {};
                const skillsDict = resume.technical_skills || {};
                
                // Flatten all skills
                const allSkills = [];
                Object.values(skillsDict).forEach(skillArray => {
                    if (Array.isArray(skillArray)) {
                        allSkills.push(...skillArray.slice(0, 5));
                    }
                });
                
                context += `
Candidate ${idx + 1}:
- Name: ${resume.name}
- File: ${resume.filename}
- Experience: ${workExp.total_years || 0} years
- Degree: ${highestQual.qualification_name || 'N/A'} from ${highestQual.college_name || 'N/A'} (${highestQual.graduation_year || 'N/A'})
- Skills: ${allSkills.slice(0, 10).join(', ') || 'None listed'}

`;
            });
            
            return context;
        }

        // Clear chat
        function clearChat() {
            const messagesContainer = document.getElementById('chatMessages');
            const typingIndicator = document.getElementById('typingIndicator');
            
            messagesContainer.innerHTML = `
                <div class="message bot">
                    <div class="message-content">
                        Chat cleared! ✨ Ask me another question about the candidates.
                    </div>
                </div>
            `;
            
            messagesContainer.appendChild(typingIndicator);
        }
    </script>
</body>
</html>
"""


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CREATE HTML FILE AND START SERVER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def setup_chatbot():
    """Setup chatbot HTML and start web server"""
    
    print("=" * 80)
    print("🚀 RESUME CHATBOT - Web Server Setup")
    print("=" * 80)
    
    # Find latest JSON file
    json_files = sorted(Path(".").glob("resume_database_*.json"), reverse=True)
    
    if not json_files:
        print("\n❌ No resume database JSON found!")
        print("Please run the resume parser first to generate the JSON file.")
        return
    
    json_file = json_files[0]
    print(f"\n📁 Found JSON: {json_file}")
    
    # Copy JSON to resume_data.json for auto-loading
    try:
        with open(json_file, 'r', encoding='utf-8') as f:
            data = json.load(f)
        
        with open('resume_data.json', 'w', encoding='utf-8') as f:
            json.dump(data, f, indent=2, ensure_ascii=False)
        
        print(f"✅ Copied to: resume_data.json")
        
    except Exception as e:
        print(f"❌ Error copying JSON: {e}")
        return
    
    # Create HTML file
    try:
        with open('resume_chatbot.html', 'w', encoding='utf-8') as f:
            f.write(HTML_TEMPLATE)
        
        print(f"✅ Created: resume_chatbot.html")
        
    except Exception as e:
        print(f"❌ Error creating HTML: {e}")
        return
    
    # Start web server
    PORT = 8000
    
    print(f"\n🌐 Starting web server on port {PORT}...")
    print(f"📊 Loaded {len(data.get('resumes', []))} resumes")
    
    try:
        Handler = http.server.SimpleHTTPRequestHandler
        
        with socketserver.TCPServer(("", PORT), Handler) as httpd:
            url = f"http://localhost:{PORT}/resume_chatbot.html"
            
            print(f"\n✅ Server running!")
            print("=" * 80)
            print(f"🔗 Open in browser: {url}")
            print("=" * 80)
            print(f"\n⚠️  IMPORTANT: Make sure Ollama is running:")
            print(f"   ollama serve")
            print(f"   ollama pull llama3.2:1b")
            print("\n🛑 Press Ctrl+C to stop the server\n")
            
            # Auto-open browser
            time.sleep(1)
            webbrowser.open(url)
            
            # Serve forever
            httpd.serve_forever()
            
    except KeyboardInterrupt:
        print("\n\n👋 Server stopped!")
    except OSError as e:
        if "Address already in use" in str(e):
            print(f"\n❌ Port {PORT} is already in use!")
            print(f"Try opening: http://localhost:{PORT}/resume_chatbot.html")
        else:
            print(f"\n❌ Error starting server: {e}")


if __name__ == "__main__":
    setup_chatbot()
