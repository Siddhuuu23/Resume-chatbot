# 9. BATCH PROCESS FOLDER (WITH PARALLEL PROCESSING)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def process_folder_parallel(folder_path, max_workers=2):
    """Process all resumes in parallel (YOUR VERSION)"""
    folder = Path(folder_path)
    if not folder.exists():
        logger.error(f"Folder not found: {folder_path}")
        return None
    
    pdf_files = list(folder.glob("*.pdf"))
    if not pdf_files:
        logger.error(f"No PDF files found in: {folder_path}")
        return None
    
    results = {
        "total_resumes": len(pdf_files),
        "processed_at": datetime.now().isoformat(),
        "resumes": []
    }
    
    logger.info(f"Found {len(pdf_files)} resume(s)")
    logger.info(f"Processing with {max_workers} parallel worker(s)\n")
    
    processed = 0
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {executor.submit(process_resume, str(pdf_file)): pdf_file for pdf_file in pdf_files}
        
        for future in as_completed(futures):
            pdf_file = futures[future]
            processed += 1
            try:
                data = future.result()
                results["resumes"].append(data)
            except Exception as e:
                logger.error(f"[{processed}/{len(pdf_files)}] {pdf_file.name}: {str(e)}")
    
    return results


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 10. EXPORT TO JSON
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def export_to_json(results):
    """Export results to JSON file"""
    output_file = f"resume_database_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
    
    with open(output_file, 'w', encoding='utf-8') as f:
        json.dump(results, f, indent=2, ensure_ascii=False)
    
    logger.info(f"💾 Saved to: {output_file}")
    return output_file


